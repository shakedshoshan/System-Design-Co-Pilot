{
  "info": {
    "name": "Architecture Co-Pilot",
    "description": "System Design Co-Pilot FastAPI. Postman Cloud: workspace **architecture-co-pilot**, collection id `c479fe3d-3c7f-46c5-b1ea-0dee09c066a7`. Collection vars: `baseUrl` (default `http://127.0.0.1:8000`), `sessionId` (UUID from Create session), `artifactId` (UUID from List session artifacts).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "System",
      "description": "Liveness, readiness, and OpenAPI (root paths â€” not under /api/v1).",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              {
                "key": "X-Request-ID",
                "value": "",
                "description": "Optional; enable and set to correlate logs.",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/health",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["health"]
            },
            "description": "Example: `GET http://127.0.0.1:8000/health`. Body: `{ data, meta }`."
          },
          "response": []
        },
        {
          "name": "Ready",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              {
                "key": "X-Request-ID",
                "value": "",
                "description": "Optional correlation id.",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/ready",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["ready"]
            },
            "description": "Example: `GET http://127.0.0.1:8000/ready`. 503 if DB unreachable."
          },
          "response": []
        },
        {
          "name": "OpenAPI JSON",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/openapi.json",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["openapi.json"]
            },
            "description": "Example: `GET http://127.0.0.1:8000/openapi.json`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "API v1",
      "description": "Product routes â€” FastAPI prefix `/api/v1` (architecture_copilot router).",
      "item": [
        {
          "name": "Sessions",
          "description": "Design sessions; `phase=product` uses LangGraph Phase 1 (guided Q + PRD). `phase=architecture`: PATCH to advance (needs PRD), then POST .../architecture/run for the five-agent pipeline; free-form chat uses single-call Step 4.",
          "item": [
            {
              "name": "Create session",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"URL shortener idea\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/sessions",
                  "protocol": "http",
                  "host": ["127", "0", "0", "1"],
                  "port": "8000",
                  "path": ["api", "v1", "sessions"]
                },
                "description": "Example: `POST http://127.0.0.1:8000/api/v1/sessions`. 201 â€” `data.session`."
              },
              "response": []
            },
            {
              "name": "List sessions",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  {
                    "key": "X-Request-ID",
                    "value": "",
                    "description": "Optional correlation id.",
                    "disabled": true
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/sessions?limit=50&offset=0",
                  "protocol": "http",
                  "host": ["127", "0", "0", "1"],
                  "port": "8000",
                  "path": ["api", "v1", "sessions"],
                  "query": [
                    { "key": "limit", "value": "50", "description": "1â€“200, default 50" },
                    { "key": "offset", "value": "0", "description": "Pagination offset" }
                  ]
                },
                "description": "Returns `data.sessions` (array of `{ id, title, phase, updated_at }`), most recently updated first."
              },
              "response": []
            },
            {
              "name": "Get session",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  {
                    "key": "X-Request-ID",
                    "value": "",
                    "description": "Optional correlation id.",
                    "disabled": true
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}",
                  "protocol": "http",
                  "host": ["127", "0", "0", "1"],
                  "port": "8000",
                  "path": ["api", "v1", "sessions", "{{sessionId}}"]
                },
                "description": "Returns `data.session` for deep links / UI header."
              },
              "response": []
            },
            {
              "name": "List session artifacts",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  {
                    "key": "X-Request-ID",
                    "value": "",
                    "description": "Optional correlation id.",
                    "disabled": true
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/artifacts",
                  "protocol": "http",
                  "host": ["127", "0", "0", "1"],
                  "port": "8000",
                  "path": ["api", "v1", "sessions", "{{sessionId}}", "artifacts"]
                },
                "description": "Metadata only: `data.artifacts` â€” `id`, `artifact_type`, `version`, `created_at` (no bodies)."
              },
              "response": []
            },
            {
              "name": "Get session artifact",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  {
                    "key": "X-Request-ID",
                    "value": "",
                    "description": "Optional correlation id.",
                    "disabled": true
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/artifacts/{{artifactId}}",
                  "protocol": "http",
                  "host": ["127", "0", "0", "1"],
                  "port": "8000",
                  "path": ["api", "v1", "sessions", "{{sessionId}}", "artifacts", "{{artifactId}}"]
                },
                "description": "Returns `data.artifact` including `content` (markdown/JSON text as stored)."
              },
              "response": []
            },
            {
              "name": "List session messages",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  {
                    "key": "X-Request-ID",
                    "value": "",
                    "description": "Optional correlation id.",
                    "disabled": true
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/messages?limit=100",
                  "protocol": "http",
                  "host": ["127", "0", "0", "1"],
                  "port": "8000",
                  "path": ["api", "v1", "sessions", "{{sessionId}}", "messages"],
                  "query": [
                    {
                      "key": "limit",
                      "value": "100",
                      "description": "1â€“500, default 100"
                    }
                  ]
                },
                "description": "Returns `data.messages` ordered oldest-first. Use to poll after HTTP 202 from chat or architecture/run when `KAFKA_ENABLED` + `KAFKA_ASYNC_RUNS` and the worker processes the job."
              },
              "response": []
            },
            {
              "name": "Chat (product phase)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"content\": \"I want to build a URL shortener for internal tools. What should I clarify first?\",\n  \"product_action\": \"default\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/chat",
                  "protocol": "http",
                  "host": ["127", "0", "0", "1"],
                  "port": "8000",
                  "path": ["api", "v1", "sessions", "{{sessionId}}", "chat"]
                },
                "description": "When session `phase` is `product`, runs LangGraph (guided questioning, optional PRD synthesis). Optional `product_action`: `default` | `synthesize_prd` (force PRD). Response may include `prd_artifact_id`, `prd_version`, `phase1_ready_for_architecture`. With `KAFKA_ENABLED` + `KAFKA_ASYNC_RUNS`, returns **202** and `data.queued_agent_run` â€” run `poetry run worker` and poll List session messages."
              },
              "response": []
            },
            {
              "name": "Chat â€” force PRD synthesis",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"content\": \"Please generate the PRD now from what we have.\",\n  \"product_action\": \"synthesize_prd\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/chat",
                  "protocol": "http",
                  "host": ["127", "0", "0", "1"],
                  "port": "8000",
                  "path": ["api", "v1", "sessions", "{{sessionId}}", "chat"]
                },
                "description": "Same route as Chat (product phase); forces the PRD synthesis node even if the model would still ask questions."
              },
              "response": []
            },
            {
              "name": "Patch session â€” phase to architecture",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phase\": \"architecture\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}",
                  "protocol": "http",
                  "host": ["127", "0", "0", "1"],
                  "port": "8000",
                  "path": ["api", "v1", "sessions", "{{sessionId}}"]
                },
                "description": "Requires at least one `prd` artifact. Sets `sessions.phase` to `architecture`. Idempotent if already architecture."
              },
              "response": []
            },
            {
              "name": "Run architecture pipeline",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"notes\": \"Prefer managed Postgres; low initial traffic.\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/architecture/run",
                  "protocol": "http",
                  "host": ["127", "0", "0", "1"],
                  "port": "8000",
                  "path": ["api", "v1", "sessions", "{{sessionId}}", "architecture", "run"]
                },
                "description": "Session must be `architecture` phase with a PRD. Runs five LangGraph agents; saves artifacts `architecture_*` and an assistant message. Optional `notes` (omit or null for none). Five LLM calls â€” allow time / raise `LLM_TIMEOUT_SECONDS` if needed. With `KAFKA_ENABLED` + `KAFKA_ASYNC_RUNS`, returns **202** and `data.queued_agent_run` â€” worker completes the pipeline; poll List session messages."
              },
              "response": []
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "sessionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "artifactId",
      "value": "",
      "type": "string"
    }
  ]
}
