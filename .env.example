# Copy to `.env` at the repo root. Never commit secrets.

# --- PostgreSQL (API + Alembic) ---
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE
# URL-encode special characters in the password (@ # : / ? etc.).
#
# Docker Compose (this repo): app / app, DB system_design_copilot, host port 5433
DATABASE_URL=postgresql+psycopg://app:app@localhost:5433/system_design_copilot
#
# pgAdmin (Docker): Host localhost, Port 5433, User app, Password app

# --- LLM (Step 4+) ---
OPENAI_API_KEY=
# LLM_MODEL=gpt-4o
# LLM_TIMEOUT_SECONDS=120
# LLM_CONTEXT_MESSAGE_LIMIT=50
# LLM_MAX_OUTPUT_CHARS=32000

# --- Kafka (Compose: localhost:9092) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Next.js ---
NEXT_PUBLIC_API_URL=http://localhost:8000
# API_INTERNAL_URL=http://host.docker.internal:8000

# --- Optional tuning ---
# APP_ENV=local
# LOG_TO_FILE=false
# LOG_LEVEL=INFO

# --- OpenTelemetry (later) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=system-design-copilot-api
