# Copy to `.env` at the repo root (or load per-app — see README). Never commit real secrets.

# --- PostgreSQL (API + Alembic; Docker Compose Step 1: localhost:5432) ---
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/system_design_copilot

# --- LLM (Step 4+; use the provider you configure in code) ---
# OpenAI-compatible or provider-specific key
OPENAI_API_KEY=
# Optional: override default model id
# LLM_MODEL=gpt-4o

# --- Kafka (API producers + worker; Docker Compose Step 1: localhost:9092) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# --- API (FastAPI) ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated browser origins (Next.js dev server)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Next.js (`apps/web`) ---
# Public base URL of the FastAPI service (browser / client components)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Optional: server-side fetch / rewrites target (if different from public URL)
# API_INTERNAL_URL=http://host.docker.internal:8000

# --- OpenTelemetry (later steps) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=system-design-copilot-api
